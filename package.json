{
  "name": "foco-vzla",
  "version": "0.1.0",
  "description": "FOCO — Coordinación de ayuda ciudadana tras el doblete sísmico de Venezuela (jun 2026)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run tests/payload.test.js tests/autocomplete.test.js tests/prioridad.test.js",
    "test:rules": "vitest run tests/rules.test.js",
    "emulators": "firebase emulators:start --only firestore,auth",
    "deploy": "vite build && firebase deploy",
    "deploy:hosting": "vite build && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "grant:coord": "node scripts/grant-coordinator.mjs",
    "prep:lugares": "node scripts/extract-lugares.mjs"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "geofire-common": "^6.0.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "firebase-admin": "^13.0.0",
    "svelte": "^4.2.19",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.0"
  }
}
